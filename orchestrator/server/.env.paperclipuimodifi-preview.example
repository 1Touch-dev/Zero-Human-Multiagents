# Copy to .env.paperclipuimodifi-preview on the server (not committed).
# Public: http://<HOST>:3301  |  App binds 127.0.0.1:3302 (see systemd proxy)
# If DATABASE_URL matches another Paperclip instance, point this at that instance's
# ~/.paperclip/instances/<id>/secrets/master.key so encrypted tokens (e.g. Telegram) decrypt.
# PAPERCLIP_SECRETS_MASTER_KEY_FILE=/home/<user>/.paperclip/instances/default/secrets/master.key
PAPERCLIP_INSTANCE_ID=uimodifi-preview
PORT=3302
HOST=127.0.0.1
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_AUTH_PUBLIC_BASE_URL=http://54.198.208.79:3301
PAPERCLIP_ALLOWED_HOSTNAMES=54.198.208.79
DATABASE_URL=postgresql://paperclip:paperclip@localhost:5432/paperclip
PAPERCLIP_AUTH_BASE_URL_MODE=explicit
BETTER_AUTH_SECRET=use-same-value-as-orchestrator-server-env
BETTER_AUTH_URL=http://54.198.208.79:3301
BETTER_AUTH_BASE_URL=http://54.198.208.79:3301
